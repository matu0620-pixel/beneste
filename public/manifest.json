{
  "manifest_version": 3,
  "name": "ベネステAI検索",
  "description": "ベネフィットステーションを巡回し、あなただけのAIエージェントが学習・サジェストします。",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "ベネステAI検索を開く",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://bs.benefit-one.inc/*",
    "https://*.benefit-one.inc/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://bs.benefit-one.inc/*",
        "https://*.benefit-one.inc/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
